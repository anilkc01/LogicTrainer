# Unity generated folders — do NOT commit these
/Library/
/Temp/
/Obj/
/Build/
/Builds/
/Logs/
/UserSettings/
/MemoryCaptures/
/Recordings/

# Asset Store cache
/[Aa]ssets/AssetStoreTools*

# Visual Studio / Rider / VS Code
.vs/
.vscode/
*.csproj
*.unityproj
*.sln
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
.idea/

# OS files
.DS_Store
Thumbs.db

# Autogenerated meta files for ignored folders (optional, usually fine to keep .meta for tracked assets)
/Build/*.meta
/Logs/*.meta

# Android/Build artifacts
*.apk
*.aab
*.unitypackage

# Crash reports / cache
sysinfo.txt
crashlytics-build.properties
/.utmp/
